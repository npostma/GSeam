; toolchange.ngc - safe toolchange WITH automatic comparative tool-length
; measurement on a fixed tool sensor (position configured in the INI).
;
; Works two ways:
;   - via REMAP=M6 in the INI (recommended): every "Tn M6" ends up here
;   - via "O <toolchange> call" (gseam --insert-toolchange-call)
;
; The idea (comparative - no absolute calibration needed, collet stickout
; may differ on every change):
;   1) measure the CURRENT tool on the sensor -> reference work-Z
;   2) park high, M0: swap the tool, cycle start
;   3) measure the NEW tool on the sensor
;   4) shift G54-Z so the new tool has the same work-Z (G10 L20)
;
; ONE-TIME setup: mount the sensor at a fixed spot, fill [TOOLSENSOR] in
; the INI (MACHINE coordinates, G53!) and OR the sensor input into the
; probe signal in HAL. While X and Y are both 0 the routine falls back to
; the old behaviour: park + M0, without measuring.
;
; Example INI section:
;   [TOOLSENSOR]
;   X = 18
;   Y = 565
;   PROBE_START_Z = -250     ; G53-Z where the downward search starts.
;                            ; MUST clear the trigger point of your
;                            ; LONGEST tool - the move here is a rapid!
;   MAX_DEPTH = 220          ; max search stroke down, mm
;   FAST_F = 400             ; search feed = speed of the first touch
;   SLOW_F = 10              ; re-measure feed, defines the accuracy

O<toolchange> sub

  #<sx>     = #<_ini[TOOLSENSOR]X>          ; sensor position, G53 machine-mm
  #<sy>     = #<_ini[TOOLSENSOR]Y>
  #<zstart> = #<_ini[TOOLSENSOR]PROBE_START_Z>  ; G53-Z where probing starts
  #<zdepth> = #<_ini[TOOLSENSOR]MAX_DEPTH>      ; max search stroke down, mm
  #<f_fast> = #<_ini[TOOLSENSOR]FAST_F>
  #<f_slow> = #<_ini[TOOLSENSOR]SLOW_F>

  ; clamp the stroke to 1mm above the Z soft limit: LinuxCNC refuses a
  ; probe move whose ENDPOINT lies outside the limits up front (the
  ; routine would just stall at start height)
  #<zroom> = [#<zstart> - #<_ini[AXIS_Z]MIN_LIMIT> - 1]
  O105 IF [#<zdepth> GT #<zroom>]
    #<zdepth> = #<zroom>
  O105 ENDIF

  ; history log: APPEND so you can always see afterwards what happened
  (LOGAPPEND,toolchange.log)
  (LOG, ==== toolchange: from T#<_current_tool> to T#<_selected_tool> ====)

  ; ===== sensor not configured yet -> classic behaviour =====
  O100 IF [[#<sx> EQ 0] AND [#<sy> EQ 0]]
    (LOG, sensor not configured - change WITHOUT measurement)
    (LOGCLOSE)
    G90
    G53 G0 Z0
    G53 G0 X0 Y0
    (MSG, Change the tool. NOTE: no length measurement - sensor not configured)
    M0
    O110 IF [#<_selected_tool> GE 0]
      M61 Q#<_selected_tool>
    O110 ENDIF
    O<toolchange> return
  O100 ENDIF

  ; ===== 1: reference - current tool on the sensor =====
  G90
  G21
  G53 G0 Z0
  G53 G0 X[#<sx>] Y[#<sy>]
  G53 G0 Z[#<zstart>]
  G91
  F#<f_fast>
  G38.3 Z-[#<zdepth>]
  O120 IF [#5070 EQ 0]
    G90
    #<zstop> = #<_abs_z>
    G53 G0 Z0
    (LOG, ERROR: tool sensor not reached for the reference - stopped at machine-Z #<zstop>)
    (LOGCLOSE)
    (MSG, Tool sensor NOT reached for the reference - NO measurement! Press ESCAPE to abort)
    M0
    O<toolchange> return
  O120 ENDIF
  G0 Z1
  F#<f_slow>
  G38.3 Z-2
  O121 IF [#5070 EQ 0]
    G90
    G53 G0 Z0
    (LOG, ERROR: tool sensor lost during reference re-measure - aborted)
    (LOGCLOSE)
    (MSG, Tool sensor lost during reference re-measure - press ESCAPE to abort)
    M0
    O<toolchange> return
  O121 ENDIF
  G90
  #<zref> = #5063                 ; sensor work-Z with the CURRENT tool
  (LOG, reference T#<_current_tool>: sensor work-Z = #<zref>)

  ; WATCHDOG: the OLD tool must still be the length it had at its own
  ; change measurement (the anchor). A deviation means it broke during
  ; the operation, slipped in the collet, or was swapped unmeasured.
  ; Proceeding would pass the breakage on to the new tool as a frame shift.
  ; On mismatch the old tool's measurement is worthless, but the FRAME is
  ; still valid (anchored while the tool was whole) - so we can substitute
  ; the anchor as reference and continue correctly; only the broken tool's
  ; work needs redoing afterwards. ESCAPE at the pause stops instead.
  O160 IF [EXISTS[#<_sensor_anchor>]]
    O161 IF [[#<_sensor_anchor> GT -9000] AND [ABS[#<zref> - #<_sensor_anchor>] GT 0.5]]
      G53 G0 Z0
      (LOG, WARNING: old tool changed length: anchor #<_sensor_anchor> vs measured #<zref> - BROKEN? - measurement discarded, anchor used)
      (DEBUG, TOOL BROKEN/SLIPPED: #<_sensor_anchor> -> #<zref>. Cycle start = swap and CONTINUE with valid frame. ESCAPE = stop)
      M0
      #<zref> = #<_sensor_anchor>
    O161 ENDIF
  O160 ENDIF

  ; ===== 2: swap =====
  G53 G0 Z0
  ; show the TARGET tool number when it is known (via Tn prefetch or REMAP);
  ; DEBUG expands parameters, MSG does not
  O150 IF [[#<_selected_tool> GT 0] AND [#<_selected_tool> NE #<_current_tool>]]
    (DEBUG, CHANGE to tool T#<_selected_tool> and press cycle start)
  O150 ELSE
    (MSG, Change the tool and press cycle start - length is measured afterwards)
  O150 ENDIF
  M0

  ; ===== 3: measure the new tool =====
  G90
  G53 G0 Z[#<zstart>]
  G91
  F#<f_fast>
  G38.3 Z-[#<zdepth>]
  O130 IF [#5070 EQ 0]
    G90
    #<zstop> = #<_abs_z>
    G53 G0 Z0
    (LOG, ERROR: tool sensor not reached with the new tool - stopped at machine-Z #<zstop>)
    (LOGCLOSE)
    (MSG, Tool sensor NOT reached with the new tool - Z0 NOT adjusted! Press ESCAPE to abort)
    M0
    O<toolchange> return
  O130 ENDIF
  G0 Z1
  F#<f_slow>
  G38.3 Z-2
  O131 IF [#5070 EQ 0]
    G90
    G53 G0 Z0
    (LOG, ERROR: tool sensor lost re-measuring the new tool - aborted)
    (LOGCLOSE)
    (MSG, Tool sensor lost re-measuring the new tool - Z0 NOT adjusted! Press ESCAPE to abort)
    M0
    O<toolchange> return
  O131 ENDIF
  G90
  #<znew> = #5063
  #<dz>   = [#<znew> - #<zref>]   ; length difference new vs old tool

  ; ===== 4: shift G54-Z to the new tool length =====
  ; we are at the trigger point of the new tool; give that point the same
  ; work-Z as the reference -> the length difference now lives in G54
  G10 L20 P1 Z[#<zref>]
  #<_sensor_anchor> = #<zref>     ; anchor for the NEXT change's breakage watchdog
  (LOG, new tool T#<_selected_tool>: sensor work-Z was #<znew>, dZ = #<dz> mm - G54-Z shifted)
  (LOGCLOSE)
  (DEBUG, Tool length compensated: dZ = #<dz> mm)

  G53 G0 Z0

  ; under REMAP: register the new tool number
  O140 IF [#<_selected_tool> GE 0]
    M61 Q#<_selected_tool>
  O140 ENDIF

O<toolchange> endsub
M2
